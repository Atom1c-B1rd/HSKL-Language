<?hs
getProduct :: Request -> Response Html
getProduct req =
    case getParam req "id" of
        Just id -> ok <div>
                       <h1>Product #<?= id ?></h1>
                       <p>Product description</p>
                   </div>
        Nothing -> notFound "Product not found"

routeProduct :: Router Get
routeProduct = get getProduct "/products/:id"
?>